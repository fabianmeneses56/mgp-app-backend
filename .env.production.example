# Copy to .env.production on the VPS (chmod 600). Never commit the real file.
NODE_ENV=production

# Database (the "db" service in docker-compose.prod.yml)
DB_HOST=db
DB_PORT=5432
DB_NAME=mgpdb
DB_USERNAME=mgp
DB_PASSWORD=change-me
# The dockerized Postgres has no TLS; Railway needed it, the VPS does not.
DB_SSL=false

PORT=3000
# Also used by docker-compose.prod.yml (--env-file) to fill {$DOMAIN} in the Caddyfile.
DOMAIN=change-me.sslip.io
HOST_API=https://change-me.sslip.io/api

JWT_SECRET=change-me

# Empty: the only client is a native (React Native/Expo) app, CORS does not apply.
CORS_ORIGIN=

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
